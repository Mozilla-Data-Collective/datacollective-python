MDC_API_KEY=your-api-key-here # https://mozilladatacollective.com/profile/credentials
MDC_DOWNLOAD_PATH=~/.mozdata/datasets
MDC_LOG_PATH=~/.mozdata
MDC_PART_SIZE=10485760        # 10 MB — increase for faster connections (e.g. 52428800 for 50 MB)
MDC_MAX_CONCURRENT_PARTS=2   # increase to 4-8 on fast connections (>10 MB/s)
