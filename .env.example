MDC_API_KEY=your-api-key-here # https://mozilladatacollective.com/profile/credentials
MDC_DOWNLOAD_PATH=~/.mozdata/datasets
MDC_LOG_PATH=~/.mozdata
MDC_PART_SIZE=26214400        # 25 MB — increase for faster connections; minimum is file_size/10000
MDC_MAX_CONCURRENT_PARTS=4   # increase to 6-8 on fast connections (>20 MB/s)
